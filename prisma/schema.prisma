generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum Language {
  ENGLISH
  SPANISH
}

enum Tier {
  A
  B
  C
  MASTER
}

model Word {
  id          Int      @id @default(autoincrement())
  word        String
  translation String
  language    Language
  tier        Tier
  category    String
  createdAt   DateTime @default(now())

  @@unique([language, word])
}