generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int            @id @default(autoincrement())
  name         String
  email        String         @unique
  password     String
  role         Role           @default(USER)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  progress     UserProgress?
}

enum Role {
  USER
  ADMIN
}

enum Language {
  ENGLISH
  SPANISH
}

enum Tier {
  A
  B
  C
  MASTER
}

model Word {
  id          Int      @id @default(autoincrement())
  word        String
  translation String
  language    Language
  tier        Tier
  category    String
  createdAt   DateTime @default(now())

  @@unique([language, word])
}

model UserProgress {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
  tier      Tier     @default(A)
  level     Int      @default(1)
  step      Int      @default(1)
  xp        Int      @default(0)
  totalXp   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}