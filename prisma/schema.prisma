generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int                 @id @default(autoincrement())
  name            String
  email           String              @unique
  password        String
  role            Role                @default(USER)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  progress        UserProgress[]
  legendProfiles  LegendProfile[]
  legendEntries   LegendSeasonEntry[]
}

enum Role {
  USER
  ADMIN
}

enum Language {
  ENGLISH
  SPANISH
}

enum Tier {
  A
  B
  C
  MASTER
}

model Word {
  id            Int        @id @default(autoincrement())
  word          String
  translation   String
  language      Language
  tier          Tier
  category      String
  cefrLevel     String     @default("A1")
  frequencyRank Int        @default(999)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())

  seenBy        WordSeen[]
  stats         WordStats?

  @@unique([language, word])
  @@index([language, cefrLevel, isActive])
}

model WordSeen {
  id      Int      @id @default(autoincrement())
  wordId  Int
  userId  Int
  seenAt  DateTime @default(now())

  word    Word     @relation(fields: [wordId], references: [id])

  @@index([userId, seenAt])
}

model WordStats {
  wordId          Int    @id
  correctCount    Int    @default(0)
  totalCount      Int    @default(0)
  avgResponseTime Float  @default(0)
  skipCount       Int    @default(0)

  word            Word   @relation(fields: [wordId], references: [id])
}

model UserProgress {
  id         Int      @id @default(autoincrement())
  userId     Int
  language   Language @default(ENGLISH)
  user       User     @relation(fields: [userId], references: [id])
  tier       Tier     @default(A)
  level      Int      @default(1)
  step       Int      @default(1)
  xp         Int      @default(0)
  totalXp    Int      @default(0)
  failStreak Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, language])
}

// ─── Legend League ────────────────────────────────────────────────────────────

enum LegendRank {
  LEGEND_V
  LEGEND_IV
  LEGEND_III
  LEGEND_II
  LEGEND_I
  WORD_MASTER
}

model LegendProfile {
  id               Int        @id @default(autoincrement())
  userId           Int
  language         Language
  rank             LegendRank @default(LEGEND_V)
  shields          Int        @default(3)
  lifetimePrestige Int        @default(0)
  bestStreak       Int        @default(0)
  totalRuns        Int        @default(0)
  lastShieldAt     DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user             User        @relation(fields: [userId], references: [id])
  runs             LegendRun[]

  @@unique([userId, language])
}

model LegendSeason {
  id        Int      @id @default(autoincrement())
  number    Int
  language  Language
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)

  entries   LegendSeasonEntry[]

  @@unique([number, language])
}

model LegendSeasonEntry {
  id           Int        @id @default(autoincrement())
  userId       Int
  seasonId     Int
  language     Language
  seasonPP     Int        @default(0)
  rank         LegendRank @default(LEGEND_V)
  finalRank    Int?
  isWordMaster Boolean    @default(false)

  user         User         @relation(fields: [userId], references: [id])
  season       LegendSeason @relation(fields: [seasonId], references: [id])

  @@unique([userId, seasonId])
}

model LegendRun {
  id            Int      @id @default(autoincrement())
  userId        Int
  language      Language
  streak        Int      @default(0)
  ppEarned      Int      @default(0)
  usedContinue  Boolean  @default(false)
  dailyRunIndex Int      @default(1)
  playedAt      DateTime @default(now())

  profile       LegendProfile @relation(fields: [userId, language], references: [userId, language])
}